#Perguntas 
#1: Quantos pedidos foram feitos por cada cliente?
SELECT c.fname, COUNT(o.idOrder) AS total_pedidos
FROM clients c
LEFT JOIN orders o ON c.idClient = o.idOrderClient
GROUP BY c.idClient;

#2: Lista de pedidos com valor total estimado ?
SELECT 
    o.idOrder, 
    o.trackingCode,
    (o.sendValue + (po.poQuantity * 500)) AS total_estimado_pedido
FROM orders o
JOIN productOrder po ON o.idOrder = po.idPOorder
ORDER BY total_estimado_pedido DESC;

#3: Como recuperar status de entrega de produtos de clientes PJ ?
SELECT pj.socialName, o.deliveryStatus, o.trackingCode
FROM clientPJ pj
JOIN clients c ON pj.idClient = c.idClient
JOIN orders o ON c.idClient = o.idOrderClient
WHERE o.deliveryStatus <> 'Entregue';
