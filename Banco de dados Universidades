CREATE DATABASE IF NOT EXISTS notas_corte_universidades;
USE notas_corte_universidades
CREATE TABLE universidades(
   idUniversity INT AUTO_INCREMENT PRIMARY KEY,
    Lname VARCHAR(100) NOT NULL,
    sigla VARCHAR(10),
    state CHAR(2),
    statuni enum('Federal','Privada') 
);
DESC universidades;

CREATE TABLE cursos (
    idCourse INT AUTO_INCREMENT PRIMARY KEY,
    Lname VARCHAR(50) NOT NULL,
    cursoType ENUM('Bacharelado', 'Licenciatura', 'Tecnólogo') DEFAULT 'Bacharelado'
);
DESC cursos;

CREATE TABLE  nota_corte (
    idCutOff INT AUTO_INCREMENT PRIMARY KEY,
    idUniversity INT,
    idCourse INT,
    year INT NOT NULL,
    score_ampla FLOAT NOT NULL,
    score_cotas FLOAT,
    period ENUM('1º Semestre', '2º Semestre') DEFAULT '1º Semestre',
    CONSTRAINT fk_university FOREIGN KEY (idUniversity) REFERENCES university(idUniversity),
    CONSTRAINT fk_course FOREIGN KEY (idCourse) REFERENCES course(idCourse)
);
DESC nota_corte;

