#1.  Qual ranking de faculdades por nota de corte (Estatística) 
SELECT u.sigla, c.name, cp.score_ampla
FROM university u
JOIN cut_off_points cp ON u.idUniversity = cp.idUniversity
JOIN course c ON cp.idCourse = c.idCourse
WHERE c.name = 'Estatística'
ORDER BY cp.score_ampla DESC;

#2. Qual a Diferença entre nota Ampla e Cotas e curso tem a maior "barreira" entre modalidades?
SELECT u.sigla, c.name, 
       (cp.score_ampla - cp.score_cotas) AS Diferenca_Pontos
FROM cut_off_points cp
JOIN university u ON cp.idUniversity = u.idUniversity
JOIN course c ON cp.idCourse = c.idCourse;
